# ============================================================================
#  Template de secrets do ESPHome.
#
#  1. Copie este arquivo para secrets.yaml (na mesma pasta).
#  2. Preencha com seus valores reais.
#  3. NUNCA versione o secrets.yaml — ele já está no .gitignore.
#
#  Para gerar a api_key (chave de 32 bytes em base64):
#  https://esphome.io/components/api.html  → botão "Generate"
#  ou: openssl rand -base64 32
#  ⚠️ Use uma chave EXCLUSIVA por device (não reaproveite de outro ESP).
# ============================================================================

wifi_ssid: "NOME_DA_SUA_REDE_WIFI"
wifi_password: "SENHA_DA_SUA_REDE_WIFI"

# Chave de criptografia da API (base64, 32 bytes). Exemplo de formato:
api_key: "kZyXyc3V0cGxhY2Vob2xkZXJfdHJvcXVlX2VzdGFfY2hhdmU="

# Senha do OTA (atualização sem fio). Escolha algo forte.
ota_password: "TROQUE_ESTA_SENHA_OTA"

# Senha do ponto de acesso de fallback (mínimo 8 caracteres).
ap_password: "TROQUE_ESTA_SENHA_AP"
